rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "jafor100khan@gmail.com";
    }
    match /categories/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "jafor100khan@gmail.com";
    }
    match /settings/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "jafor100khan@gmail.com";
    }
  }
}
