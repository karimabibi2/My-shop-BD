rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: productId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - price: number (required)
    //   - image: string (required)
    //   - category: string (required)
    //   - rating: number (optional)
    //   - isAvailable: boolean (optional)
    //   - description: string (optional)
    //   - orderPolicy: string (optional)
    //   - sizes: list (optional)
    //
    // Collection: orders
    // Document ID: orderId
    // Fields:
    //   - id: string (required)
    //   - customerName: string (required)
    //   - phone: string (required)
    //   - address: string (required)
    //   - total: number (required)
    //   - status: string (required)
    //   - date: string (required)
    //   - items: list (required)
    //   - paymentMethod: string (optional)
    //   - uid: string (optional)
    //
    // Collection: categories
    // Document ID: categoryId
    // Fields:
    //   - name: string (required)
    //
    // Collection: config
    // Document ID: settings
    // Fields:
    //   - bannerImage: string
    //   - paymentMethodsImage: string
    //   - whatsappNumber: string
    //   - facebookLink: string
    //   - youtubeLink: string
    //   - tiktokLink: string
    //   - globalOrderPolicy: string
    //   - shippingRates: map
    //   - adminUsername: string
    //   - adminPassword: string
    //   - visitorCount: number
    //   - customApiKey: string
    //   - twelvedataApiKey: string
    //   - isPromoBannerEnabled: boolean
    //   - isDarkModeDefault: boolean
    //
    // Collection: carts
    // Document ID: userId
    // Fields:
    //   - items: list (required)
    //   - updatedAt: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          request.auth.token.email == "mstkarimabibi45@gmail.com" ||
          request.auth.token.email == "jafor100khan@gmail.com" ||
          request.auth.token.email == "sreemithunchandra021@gmail.com");
    }

    function isProductAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "jafor100khan@gmail.com" ||
        request.auth.token.email == "mstkarimabibi45@gmail.com" ||
        request.auth.token.email == "sreemithunchandra021@gmail.com"
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidProduct(data) {
      return data.id is string && data.id.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is number &&
             data.image is string && data.image.size() < 2000 &&
             data.category is string && data.category.size() < 100;
    }

    function isValidOrder(data) {
      return data.id is string && data.id.size() < 100 &&
             data.customerName is string && data.customerName.size() < 100 &&
             data.phone is string && data.phone.size() < 20 &&
             data.total is number &&
             data.items is list && data.items.size() < 50;
    }

    function isValidCategory(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    function isValidUser(data) {
      return data.uid is string && data.uid.size() < 100 &&
             data.email is string && data.email.size() < 100 &&
             data.role in ['admin', 'user'];
    }

    function isValidCart(data) {
      return data.items is list && data.items.size() < 50 &&
             data.updatedAt is string && data.updatedAt.size() < 100;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      allow read: if true;
      allow write: if isProductAdmin() && (request.method == 'delete' || isValidProduct(request.resource.data));
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && (resource == null || resource.data.uid == request.auth.uid));
      allow create: if (isAuthenticated() || request.resource.data.uid == 'guest') && isValidOrder(request.resource.data);
      allow update: if isAdmin() && isValidOrder(request.resource.data);
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin() && (request.method == 'delete' || isValidCategory(request.resource.data));
    }

    match /config/settings {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /config/landing {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();
    }

    match /carts/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isValidCart(request.resource.data);
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
